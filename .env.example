# Accessiflow v2.0 — Environment Configuration
# Copy to .env and fill in your values.

# ─── Canvas LMS ───────────────────────────────────────────────
# Required: Your Canvas LMS instance URL
ACCESSIFLOW_CANVAS_BASE_URL=https://canvas.yourschool.edu

# Required (auth_mode=none) or Optional (auth_mode=local/sso):
# Canvas API access token (generate in Canvas → Settings → New Access Token)
ACCESSIFLOW_CANVAS_API_TOKEN=

# Shared Canvas token for all users (optional, for auth_mode=local/sso)
ACCESSIFLOW_SHARED_CANVAS_TOKEN=

# Optional: Output directory for reports
ACCESSIFLOW_OUTPUT_DIR=output

# Optional: Max file size to check (MB)
ACCESSIFLOW_MAX_FILE_SIZE_MB=50

# ─── Authentication ───────────────────────────────────────────
# Auth mode: none (default, v1 behavior) | local (email+password) | sso
ACCESSIFLOW_AUTH_MODE=none

# Secret key for JWT signing (required for local/sso; auto-generated for none)
ACCESSIFLOW_SECRET_KEY=

# Database URL (SQLite default, PostgreSQL optional)
ACCESSIFLOW_DATABASE_URL=sqlite+aiosqlite:///data/accessiflow.db

# Default admin user (seeded on first boot when auth_mode != none)
ACCESSIFLOW_ADMIN_EMAIL=admin@localhost
ACCESSIFLOW_ADMIN_PASSWORD=change-me

# ─── SSO (only when auth_mode=sso) ───────────────────────────
# Protocol: oidc | saml
ACCESSIFLOW_SSO_PROTOCOL=oidc

# OIDC settings
ACCESSIFLOW_SSO_OIDC_DISCOVERY_URL=
ACCESSIFLOW_SSO_OIDC_CLIENT_ID=
ACCESSIFLOW_SSO_OIDC_CLIENT_SECRET=

# SAML settings
ACCESSIFLOW_SSO_SAML_METADATA_URL=
ACCESSIFLOW_SSO_SAML_ENTITY_ID=

# SSO user defaults
ACCESSIFLOW_SSO_DEFAULT_ROLE=auditor
ACCESSIFLOW_SSO_AUTO_CREATE_USERS=true

# ─── AI Provider (Optional — BYO Key) ─────────────────────────
# Supported providers: anthropic, openai, google, grok
ACCESSIFLOW_AI_PROVIDER=

# API key for your chosen provider
ACCESSIFLOW_AI_API_KEY=

# Optional: Override the default model
# Defaults: anthropic/claude-sonnet-4-20250514, gpt-4o, gemini/gemini-2.0-flash, openai/grok-3
ACCESSIFLOW_AI_MODEL=
