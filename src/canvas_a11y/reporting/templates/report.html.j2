<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accessibility Audit: {{ result.course_name }}</title>
    <style>
        /* ── Reset & Base ─────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            color: #1a1a2e;
            background: #f5f6fa;
            padding: 2rem;
        }

        /* ── Layout ───────────────────────────────────────────────── */
        .container { max-width: 1100px; margin: 0 auto; }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
        }

        /* ── Typography ───────────────────────────────────────────── */
        h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: .25rem; }
        h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; border-bottom: 2px solid #eee; padding-bottom: .5rem; }
        h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: .75rem; }
        .subtitle { color: #555; font-size: .95rem; }

        /* ── Header / Score Gauge ─────────────────────────────────── */
        .header { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
        .header-info { flex: 1; min-width: 280px; }
        .score-gauge {
            width: 140px; height: 140px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            flex-direction: column;
            font-weight: 700;
            flex-shrink: 0;
            border: 6px solid currentColor;
        }
        .score-gauge .score-value { font-size: 2.5rem; line-height: 1; }
        .score-gauge .score-label { font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; opacity: .8; }

        /* ── Score colors ─────────────────────────────────────────── */
        .score-pass  { color: #16a34a; }
        .score-warn  { color: #ca8a04; }
        .score-fail  { color: #dc2626; }
        .score-none  { color: #9ca3af; }

        .bg-pass { background: #dcfce7; }
        .bg-warn { background: #fef9c3; }
        .bg-fail { background: #fee2e2; }

        /* ── Severity badges ──────────────────────────────────────── */
        .severity-badge {
            display: inline-flex; align-items: center; gap: .3em;
            padding: .15em .6em; border-radius: 4px;
            font-size: .8rem; font-weight: 600; text-transform: uppercase;
            letter-spacing: .03em; white-space: nowrap;
        }
        .severity-critical { background: #fee2e2; color: #991b1b; }
        .severity-critical::before { content: "\26d4"; }
        .severity-serious  { background: #fed7aa; color: #9a3412; }
        .severity-serious::before  { content: "\26a0\fe0f"; }
        .severity-moderate { background: #fef9c3; color: #854d0e; }
        .severity-moderate::before { content: "\2139\fe0f"; }
        .severity-minor    { background: #f3f4f6; color: #4b5563; }
        .severity-minor::before    { content: "\2022"; }

        /* ── Summary stats ────────────────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }
        .stat-box {
            text-align: center;
            padding: .75rem;
            border-radius: 6px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }
        .stat-box .stat-value { font-size: 1.75rem; font-weight: 700; }
        .stat-box .stat-label { font-size: .78rem; color: #64748b; text-transform: uppercase; letter-spacing: .04em; }

        .stat-critical .stat-value { color: #991b1b; }
        .stat-serious  .stat-value { color: #9a3412; }
        .stat-moderate .stat-value { color: #854d0e; }
        .stat-minor    .stat-value { color: #4b5563; }
        .stat-passing  .stat-value { color: #16a34a; }
        .stat-failing  .stat-value { color: #dc2626; }

        /* ── Tables ───────────────────────────────────────────────── */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: .9rem;
        }
        thead th {
            text-align: left;
            padding: .6rem .75rem;
            background: #f8fafc;
            border-bottom: 2px solid #e2e8f0;
            font-weight: 600;
            font-size: .8rem;
            text-transform: uppercase;
            letter-spacing: .03em;
            color: #475569;
        }
        tbody td {
            padding: .55rem .75rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: top;
        }
        tbody tr:hover { background: #f8fafc; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .text-mono { font-family: "SF Mono", "Fira Code", "Consolas", monospace; font-size: .82rem; }
        .truncate { max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* ── Score pill in tables ──────────────────────────────────── */
        .score-pill {
            display: inline-block;
            padding: .1em .5em;
            border-radius: 4px;
            font-weight: 600;
            font-size: .85rem;
        }
        .score-pill.score-pass { background: #dcfce7; }
        .score-pill.score-warn { background: #fef9c3; }
        .score-pill.score-fail { background: #fee2e2; }

        /* ── Element HTML snippet ─────────────────────────────────── */
        .element-snippet {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            padding: .3em .5em;
            font-family: "SF Mono", "Fira Code", "Consolas", monospace;
            font-size: .78rem;
            max-width: 400px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: block;
            color: #334155;
        }

        /* ── Footer ───────────────────────────────────────────────── */
        .footer {
            text-align: center;
            color: #94a3b8;
            font-size: .8rem;
            padding: 1.5rem 0;
            border-top: 1px solid #e2e8f0;
            margin-top: 1rem;
        }

        /* ── WCAG link ────────────────────────────────────────────── */
        .wcag-link {
            color: #2563eb;
            text-decoration: none;
            font-size: .82rem;
        }
        .wcag-link:hover { text-decoration: underline; }

        /* ── Status badge ─────────────────────────────────────────── */
        .status-badge {
            display: inline-block;
            padding: .2em .75em;
            border-radius: 999px;
            font-weight: 600;
            font-size: .85rem;
        }
        .status-pass { background: #dcfce7; color: #166534; }
        .status-fail { background: #fee2e2; color: #991b1b; }

        /* ── Responsive ───────────────────────────────────────────── */
        @media (max-width: 768px) {
            body { padding: 1rem; }
            .header { flex-direction: column; align-items: flex-start; }
            .score-gauge { width: 100px; height: 100px; }
            .score-gauge .score-value { font-size: 1.75rem; }
            table { font-size: .8rem; }
            thead th, tbody td { padding: .4rem .5rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- ── Course Header ──────────────────────────────────────── -->
        <div class="card">
            <div class="header">
                <div class="header-info">
                    <h1>Canvas Accessibility Audit</h1>
                    <p class="subtitle">{{ result.course_name }} &mdash; Course ID {{ result.course_id }}</p>
                    <p class="subtitle">
                        {% if result.overall_score is not none and result.overall_score >= 90 %}
                            <span class="status-badge status-pass">PASSING</span>
                        {% else %}
                            <span class="status-badge status-fail">NEEDS WORK</span>
                        {% endif %}
                    </p>
                </div>
                <div class="score-gauge {{ score_class(result.overall_score) }}" role="img" aria-label="Overall score: {{ '%.1f' | format(result.overall_score or 0) }} percent">
                    <span class="score-value">{{ '%.1f' | format(result.overall_score or 0) }}%</span>
                    <span class="score-label">Overall</span>
                </div>
            </div>
        </div>

        <!-- ── Summary Statistics ─────────────────────────────────── -->
        <div class="card">
            <h2>Summary</h2>
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-value">{{ result.total_issues }}</div>
                    <div class="stat-label">Total Issues</div>
                </div>
                <div class="stat-box stat-critical">
                    <div class="stat-value">{{ result.critical_count }}</div>
                    <div class="stat-label">Critical</div>
                </div>
                <div class="stat-box stat-serious">
                    <div class="stat-value">{{ result.serious_count }}</div>
                    <div class="stat-label">Serious</div>
                </div>
                <div class="stat-box stat-moderate">
                    <div class="stat-value">{{ result.moderate_count }}</div>
                    <div class="stat-label">Moderate</div>
                </div>
                <div class="stat-box stat-minor">
                    <div class="stat-value">{{ result.minor_count }}</div>
                    <div class="stat-label">Minor</div>
                </div>
                <div class="stat-box stat-passing">
                    <div class="stat-value">{{ result.items_passing }}</div>
                    <div class="stat-label">Items Passing</div>
                </div>
                <div class="stat-box stat-failing">
                    <div class="stat-value">{{ result.items_failing }}</div>
                    <div class="stat-label">Items Failing</div>
                </div>
            </div>
        </div>

        <!-- ── Standards Compliance ──────────────────────────────── -->
        <div class="card">
            <h2>Standards Compliance</h2>
            <p class="subtitle" style="margin-bottom:1rem;">Coverage across WCAG 2.1 AA and Section 508 standards.</p>
            <div style="display:flex;gap:2rem;flex-wrap:wrap;">
                <div>
                    <h3 style="font-size:.95rem;">WCAG 2.1 AA</h3>
                    <p class="subtitle">Checks mapped to WCAG 2.1 Level A and AA success criteria.</p>
                    <p><a href="https://www.w3.org/TR/WCAG21/" target="_blank" rel="noopener" style="color:#2563eb;font-size:.88rem;">View WCAG 2.1 Guidelines</a></p>
                </div>
                <div>
                    <h3 style="font-size:.95rem;">Section 508</h3>
                    <p class="subtitle">Compliance with Revised Section 508 standards (incorporating WCAG).</p>
                    <p><a href="https://www.access-board.gov/ict/" target="_blank" rel="noopener" style="color:#2563eb;font-size:.88rem;">View Section 508 Standards</a></p>
                </div>
            </div>
        </div>

        <!-- ── Content Items ──────────────────────────────────────── -->
        {% if result.content_items %}
        <div class="card">
            <h2>Content Items</h2>
            <table>
                <thead>
                    <tr>
                        <th scope="col">Type</th>
                        <th scope="col">Title</th>
                        <th scope="col" class="text-right">Score</th>
                        <th scope="col" class="text-right">Issues</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in result.content_items | sort(attribute='score') %}
                    <tr>
                        <td>{{ item.content_type.value }}</td>
                        <td class="truncate">
                            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
                        </td>
                        <td class="text-right">
                            {% if item.score is not none %}
                                <span class="score-pill {{ score_class(item.score) }}">{{ '%.1f' | format(item.score) }}%</span>
                            {% else %}
                                <span class="score-pill score-none">&mdash;</span>
                            {% endif %}
                        </td>
                        <td class="text-right">{{ item.issues | length }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- ── File Items ─────────────────────────────────────────── -->
        {% if result.file_items %}
        <div class="card">
            <h2>File Items</h2>
            <table>
                <thead>
                    <tr>
                        <th scope="col">File</th>
                        <th scope="col">Type</th>
                        <th scope="col" class="text-right">Size</th>
                        <th scope="col" class="text-right">Score</th>
                        <th scope="col" class="text-right">Issues</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in result.file_items | sort(attribute='score') %}
                    <tr>
                        <td class="truncate">{{ item.display_name }}</td>
                        <td class="text-mono">{{ item.content_type_header }}</td>
                        <td class="text-right text-mono">{{ '%.1f' | format(item.size / 1024) }} KB</td>
                        <td class="text-right">
                            {% if item.score is not none %}
                                <span class="score-pill {{ score_class(item.score) }}">{{ '%.1f' | format(item.score) }}%</span>
                            {% else %}
                                <span class="score-pill score-none">&mdash;</span>
                            {% endif %}
                        </td>
                        <td class="text-right">{{ item.issues | length }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- ── Detailed Issues ────────────────────────────────────── -->
        {% if all_issues %}
        <div class="card">
            <h2>Issues Detail</h2>
            <p class="subtitle" style="margin-bottom: 1rem;">{{ all_issues | length }} issue{{ 's' if all_issues | length != 1 else '' }} found, ordered by severity.</p>
            <table>
                <thead>
                    <tr>
                        <th scope="col">Severity</th>
                        <th scope="col">Check</th>
                        <th scope="col">Item</th>
                        <th scope="col">WCAG</th>
                        <th scope="col">Standards</th>
                        <th scope="col">Description</th>
                        <th scope="col">Fixable</th>
                    </tr>
                </thead>
                <tbody>
                    {% for issue in all_issues %}
                    <tr>
                        <td>
                            <span class="severity-badge severity-{{ issue.severity }}">{{ issue.severity }}</span>
                        </td>
                        <td class="text-mono">{{ issue.check_id }}</td>
                        <td class="truncate">{{ issue.item_name }}</td>
                        <td>
                            <a class="wcag-link" href="https://www.w3.org/WAI/WCAG21/Understanding/{{ issue.wcag_criterion | replace('.', '') }}" target="_blank" rel="noopener" aria-label="WCAG {{ issue.wcag_criterion }}">
                                {{ issue.wcag_criterion }}
                            </a>
                        </td>
                        <td style="font-size:.82rem;">
                            {% if issue.standards %}
                                {% for cid in issue.standards.wcag_criteria[:3] %}
                                    <a class="wcag-link" href="https://www.w3.org/WAI/WCAG21/Understanding/{{ cid | replace('.', '') }}" target="_blank" rel="noopener">{{ cid }}</a>{% if not loop.last %}, {% endif %}
                                {% endfor %}
                                {% if issue.standards.section_508 %}
                                    <br><span style="color:#64748b;">508: {{ issue.standards.section_508 | join(', ') }}</span>
                                {% endif %}
                            {% endif %}
                        </td>
                        <td>
                            {{ issue.title }}
                            {% if issue.element_html %}
                                <code class="element-snippet" title="{{ issue.element_html }}">{{ issue.element_html[:120] }}</code>
                            {% endif %}
                            {% if issue.line_number %}
                                <span class="subtitle">Line {{ issue.line_number }}</span>
                            {% endif %}
                            {% if issue.standards and issue.standards.best_practice_urls %}
                                <div style="margin-top:.3rem;">
                                    {% for url in issue.standards.best_practice_urls[:2] %}
                                        <a href="{{ url }}" target="_blank" rel="noopener" style="color:#2563eb;font-size:.78rem;">Best practice guide{% if not loop.last %}, {% endif %}</a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% if issue.fixed %}
                                <span title="Fixed" aria-label="Fixed">&#10004;</span>
                            {% elif issue.auto_fixable %}
                                <span title="Auto-fixable" aria-label="Auto-fixable">&#9881;</span>
                            {% elif issue.ai_fixable %}
                                <span title="AI-fixable" aria-label="AI-fixable">&#9733;</span>
                            {% else %}
                                <span title="Manual fix required" aria-label="Manual fix required">&mdash;</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- ── Footer ─────────────────────────────────────────────── -->
        <footer class="footer">
            <p>Generated by <strong>Accessiflow</strong> on {{ generated_at }}</p>
            <p>Checks based on <a href="https://www.w3.org/TR/WCAG21/" target="_blank" rel="noopener">WCAG 2.1</a> guidelines.</p>
        </footer>
    </div>
</body>
</html>
