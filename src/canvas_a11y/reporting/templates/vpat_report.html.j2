<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VPAT Report: {{ vpat.product_name }}</title>
    <style>
        /* Professional, clean styling similar to existing report.html.j2 */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6; color: #1a1a2e; background: #f5f6fa; padding: 2rem;
        }
        .container { max-width: 1100px; margin: 0 auto; }
        .card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.08); padding: 1.5rem 2rem; margin-bottom: 1.5rem; }
        h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: .25rem; }
        h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; border-bottom: 2px solid #eee; padding-bottom: .5rem; }
        h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: .75rem; color: #2563eb; }
        .subtitle { color: #555; font-size: .95rem; }

        /* VPAT-specific */
        .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem 2rem; margin-top: 1rem; }
        .meta-grid dt { font-weight: 600; color: #475569; font-size: .9rem; }
        .meta-grid dd { color: #1a1a2e; font-size: .9rem; margin-bottom: .5rem; }

        /* Conformance level badges */
        .level-badge { display: inline-block; padding: .15em .6em; border-radius: 4px; font-size: .82rem; font-weight: 600; white-space: nowrap; }
        .level-supports { background: #dcfce7; color: #166534; }
        .level-partially { background: #fef9c3; color: #854d0e; }
        .level-does-not { background: #fee2e2; color: #991b1b; }
        .level-not-evaluated { background: #f3f4f6; color: #4b5563; }
        .level-not-applicable { background: #e0e7ff; color: #3730a3; }

        /* Summary stats */
        .stats-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; }
        .stat-item { text-align: center; padding: .75rem 1.25rem; border-radius: 6px; background: #f8fafc; border: 1px solid #e2e8f0; min-width: 100px; }
        .stat-item .val { font-size: 1.5rem; font-weight: 700; }
        .stat-item .lbl { font-size: .75rem; color: #64748b; text-transform: uppercase; }

        /* Table */
        table { width: 100%; border-collapse: collapse; font-size: .9rem; }
        thead th { text-align: left; padding: .6rem .75rem; background: #f8fafc; border-bottom: 2px solid #e2e8f0; font-weight: 600; font-size: .82rem; text-transform: uppercase; color: #475569; }
        tbody td { padding: .55rem .75rem; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
        tbody tr:hover { background: #f8fafc; }

        .criterion-id { font-family: "SF Mono","Fira Code",Consolas,monospace; font-size: .85rem; white-space: nowrap; }
        .criterion-link { color: #2563eb; text-decoration: none; }
        .criterion-link:hover { text-decoration: underline; }
        .remarks { font-size: .85rem; color: #64748b; max-width: 400px; }

        .disclaimer { background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 1rem; font-size: .88rem; color: #92400e; margin-top: 1rem; }

        .footer { text-align: center; color: #94a3b8; font-size: .8rem; padding: 1.5rem 0; border-top: 1px solid #e2e8f0; margin-top: 1rem; }

        @media (max-width: 768px) {
            body { padding: 1rem; }
            .meta-grid { grid-template-columns: 1fr; }
            table { font-size: .8rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="card">
            <h1>Voluntary Product Accessibility Template (VPAT)</h1>
            <p class="subtitle">VPAT 2.x WCAG Edition — {{ vpat.product_name }}</p>

            <dl class="meta-grid">
                <dt>Product Name</dt>
                <dd>{{ vpat.product_name }}</dd>
                <dt>Report Date</dt>
                <dd>{{ vpat.report_date }}</dd>
                <dt>Evaluation Methods</dt>
                <dd>Automated scanning using Accessiflow</dd>
                <dt>Applicable Standard</dt>
                <dd>WCAG 2.1 Level A &amp; AA</dd>
            </dl>
        </div>

        <!-- Summary -->
        <div class="card">
            <h2>Conformance Summary</h2>
            <div class="stats-row">
                <div class="stat-item">
                    <div class="val" style="color:#166534;">{{ vpat.supports_count }}</div>
                    <div class="lbl">Supports</div>
                </div>
                <div class="stat-item">
                    <div class="val" style="color:#854d0e;">{{ vpat.partially_supports_count }}</div>
                    <div class="lbl">Partially Supports</div>
                </div>
                <div class="stat-item">
                    <div class="val" style="color:#991b1b;">{{ vpat.does_not_support_count }}</div>
                    <div class="lbl">Does Not Support</div>
                </div>
                <div class="stat-item">
                    <div class="val" style="color:#4b5563;">{{ vpat.not_evaluated_count }}</div>
                    <div class="lbl">Not Evaluated</div>
                </div>
            </div>
        </div>

        <!-- WCAG Tables by Principle -->
        {% for principle in principles %}
        {% if grouped_rows[principle] %}
        <div class="card">
            <h2>{{ principle }}</h2>
            <table>
                <thead>
                    <tr>
                        <th scope="col" style="width:15%;">Criterion</th>
                        <th scope="col" style="width:25%;">Name</th>
                        <th scope="col" style="width:8%;">Level</th>
                        <th scope="col" style="width:18%;">Conformance</th>
                        <th scope="col">Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in grouped_rows[principle] %}
                    <tr>
                        <td class="criterion-id">
                            {% if wcag_criteria.get(row.criterion_id) %}
                            <a class="criterion-link" href="{{ wcag_criteria[row.criterion_id].url }}" target="_blank" rel="noopener">{{ row.criterion_id }}</a>
                            {% else %}
                            {{ row.criterion_id }}
                            {% endif %}
                        </td>
                        <td>{{ row.criterion_name }}</td>
                        <td>
                            {% if wcag_criteria.get(row.criterion_id) %}
                            {{ wcag_criteria[row.criterion_id].level }}
                            {% endif %}
                        </td>
                        <td>
                            {% if row.level == "Supports" %}
                            <span class="level-badge level-supports">Supports</span>
                            {% elif row.level == "Partially Supports" %}
                            <span class="level-badge level-partially">Partially Supports</span>
                            {% elif row.level == "Does Not Support" %}
                            <span class="level-badge level-does-not">Does Not Support</span>
                            {% elif row.level == "Not Evaluated" %}
                            <span class="level-badge level-not-evaluated">Not Evaluated</span>
                            {% elif row.level == "Not Applicable" %}
                            <span class="level-badge level-not-applicable">Not Applicable</span>
                            {% endif %}
                        </td>
                        <td class="remarks">{{ row.remarks }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
        {% endfor %}

        <!-- Disclaimer -->
        <div class="card">
            <div class="disclaimer">
                <strong>Disclaimer:</strong> This VPAT was generated by automated scanning only.
                Automated tools can detect approximately 30-40% of accessibility issues.
                A comprehensive accessibility evaluation requires manual testing,
                assistive technology testing, and user testing. This report should be
                supplemented with manual review for a complete accessibility assessment.
            </div>
            {% if vpat.notes %}
            <p style="margin-top:1rem;font-size:.9rem;">{{ vpat.notes }}</p>
            {% endif %}
        </div>

        <!-- Footer -->
        <footer class="footer">
            <p>Generated by <strong>Accessiflow</strong> on {{ generated_at }}</p>
            <p>VPAT format based on <a href="https://www.itic.org/policy/accessibility/vpat" target="_blank" rel="noopener">ITI VPAT 2.x</a></p>
        </footer>
    </div>
</body>
</html>
